# ─────────────────────────────────────────────────────────────────────────────
# Smart Union Postbox — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=postbox_db
DB_USER=postbox_user
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis (Celery broker + Channels layer + Rate-limit cache)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0

# S3 / MinIO — Presigned URL uploads
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=postbox-uploads
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9000  # MinIO local; remove for real AWS S3
AWS_S3_PRESIGNED_URL_EXPIRY=3600  # seconds

# Union Parishad — Default jurisdiction for NID matching
UP_DISTRICT=ঢাকা
UP_UPAZILA=ধামরাই
UP_UNION_NAME=সানোরা

# Rate Limiting
RATE_LIMIT_COMPLAINTS_PER_HOUR=10
RATE_LIMIT_UPLOADS_PER_HOUR=20
